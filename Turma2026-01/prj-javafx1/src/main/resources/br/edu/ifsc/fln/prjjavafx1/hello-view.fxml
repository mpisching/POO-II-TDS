<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifsc.fln.prjjavafx1.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" text="AULA DE POO II" />
   <AnchorPane prefHeight="252.0" prefWidth="200.0">
      <children>
         <Button layoutX="45.0" layoutY="190.0" mnemonicParsing="false" onAction="#btOnAction" text="Ok" />
         <Button layoutX="108.0" layoutY="190.0" mnemonicParsing="false" onAction="#btLimparOnAction" text="Limpar" />
         <CheckBox fx:id="cbHabilitarEntrada" layoutX="27.0" layoutY="34.0" mnemonicParsing="false" onAction="#cbHabilitarEntradaOnAction" selected="true" text="Habilitar entrada" />
         <Label layoutX="27.0" layoutY="67.0" text="Nome:" />
         <TextField fx:id="tfNome" layoutX="63.0" layoutY="63.0" prefHeight="26.0" prefWidth="134.0" promptText="informe o seu nome" />
         <Label layoutX="-5.0" layoutY="100.0" text="Sobrenome:" />
         <TextField fx:id="tfSobrenome" layoutX="63.0" layoutY="95.0" prefHeight="26.0" prefWidth="134.0" />
         <Label fx:id="lbNomeCompleto" layoutX="-1.0" layoutY="161.0" prefHeight="18.0" prefWidth="202.0" />
         <Label layoutX="28.0" layoutY="133.0" text="Idade:" />
         <TextField fx:id="tfIdade" layoutX="63.0" layoutY="128.0" prefHeight="26.0" prefWidth="134.0" />
      </children>
   </AnchorPane>
    <Button onAction="#onHelloButtonClick" text="Hello!" />
</VBox>
